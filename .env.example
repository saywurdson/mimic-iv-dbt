# Copy to `.env` and adjust to your machine, then `set -a && source .env && set +a`
# (or use direnv) before running dbt. The Streamlit dashboard loads `.env`
# automatically via python-dotenv.
#
# All values have sensible in-container defaults (see mimic_iv_dbt/profiles.yml and
# mimic_iv_dbt/dbt_project.yml); override here only if your paths differ.

# --- Output databases (DuckDB) -------------------------------------------------
# Built OMOP CDM database (the dbt `dev` target output). Use an absolute path so
# dbt and the dashboard resolve it identically.
MIMIC_IV_DB_PATH=/workspaces/mimic-iv-dbt/mimic_iv_omop.db
# Disposable scratch database attached during the build (staging + intermediate).
MIMIC_IV_DELETE_DB_PATH=/workspaces/mimic-iv-dbt/mimic_iv_delete.db

# --- Source data (download separately; see README) -----------------------------
# OMOP Athena vocabulary TSVs (CONCEPT.csv, CONCEPT_RELATIONSHIP.csv, ...).
OMOP_VOCAB_PATH=/workspaces/mimic-iv-dbt/mimic_iv_dbt/data
# MIMIC-IV relational data root (per-module subdirs of *.csv.gz).
MIMIC_IV_PATH=/workspaces/mimic-iv-dbt/data/mimiciv

# --- PhysioNet credentials (for the mimiciv.py download) -----------------------
# Leave blank to be prompted interactively (recommended -- nothing stored on disk).
# Populate to run unattended; .env is gitignored so values are never committed.
PHYSIONET_USER=
PHYSIONET_PASSWORD=

# --- MIMIC-IV download (mimiciv.py) --------------------------------------------
# Optional dataset version overrides:
# MIMIC_IV_VERSION=3.1
# MIMIC_IV_NOTE_VERSION=2.2
